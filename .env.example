# Copy this file to .env for local-only overrides.

# --- Shared app profile ---
# Select the deployment profile config file. Relative paths are resolved from repo root.
APP_PROFILE_CONFIG_PATH=app-profiles/baby-app-config.yaml

# --- Backend runtime ---
APP_HOST=0.0.0.0
APP_PORT=8090
DB_PATH=backend/database-dev.db
# DATABASE_URL=sqlite:///backend/database-dev.db
CORS_ALLOWED_ORIGINS=http://localhost:3005
SESSION_TTL_DAYS=30
FRONTEND_DIST_PATH=
CUSTOM_ICON_STORAGE_DIR=backend/custom-icon-assets

# --- Google Calendar integration ---
GOOGLE_CREDENTIALS_PATH=google-service-account-creds.json
# GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIME_ZONE=UTC
GOOGLE_CALENDAR_SHARE_ROLE=writer

# Set to 1 to force outbound Google Calendar writes to fail in a retryable way
# so you can test the queued-retry UX without touching Google.
FORCE_GCAL_QUEUE_RETRY_TEST=0

# Set to 1 to disable the background queue worker when debugging backend flows.
DISABLE_CALENDAR_SYNC_WORKER=0

# Set to 1 to enable the live Google Calendar integration tests.
ENABLE_LIVE_CALENDAR_TESTS=0

# --- Frontend runtime (Vite) ---
VITE_API_BASE_URL=http://localhost:8090
VITE_GOOGLE_SYNC_POLL_INTERVAL_MS=3600000
